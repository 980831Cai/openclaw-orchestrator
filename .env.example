# OpenClaw Orchestrator Environment Variables
# Copy this file to .env and fill in your values

# ─── Server ───
# Port for the orchestrator server (default: 3721)
PORT=3721

# ─── OpenClaw Home ───
# Base directory for all OpenClaw data (default: ~/.openclaw)
# OPENCLAW_HOME=/path/to/.openclaw

# ─── CORS ───
# Allowed origin for CORS (default: http://localhost:5173)
CORS_ORIGIN=http://localhost:5173

# ─── API Authentication ───
# API key for securing endpoints (empty = no auth, dev mode)
# API_KEY=your-secret-api-key-here

# ─── OpenClaw Gateway ───
# WebSocket URL for Gateway control plane (default: ws://localhost:18789)
# OPENCLAW_GATEWAY_URL=ws://localhost:18789

# Auth token for Gateway (optional, for remote connections)
# OPENCLAW_GATEWAY_TOKEN=your-gateway-token

# ─── OpenClaw Webhook ───
# Base URL for Webhook server (default: http://localhost:3578)
# OPENCLAW_WEBHOOK_URL=http://localhost:3578

# ─── Database ───
# Custom database path (default: $OPENCLAW_HOME/orchestrator.sqlite)
# DB_PATH=/path/to/custom.db
